# Copy this file to `backend/.env` and fill in real values.
# NEVER commit the real .env — it is gitignored.

NODE_ENV=development
PORT=3000

# PostgreSQL connection (used once the database is added)
DATABASE_URL=postgresql://omakase:omakase@localhost:5432/omakase

# AI provider key — SERVER-SIDE ONLY. Default provider: Google Gemini (free tier).
# Get a free key (no credit card) at https://aistudio.google.com.
# Leave GEMINI_API_KEY empty to run AI-off (deterministic keyword fallback).
GEMINI_API_KEY=
# Use a model with free-tier quota for your account/region. gemini-2.0-flash has
# zero free quota in some regions; gemini-2.5-flash works on the free tier.
GEMINI_MODEL=gemini-2.5-flash
